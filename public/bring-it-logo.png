<script>
	document.addEventListener('DOMContentLoaded', function () {
		const menuItems = document.querySelectorAll('.tab-netsuite__menu ul li, .tab-netsuite__menu ol li');
		const tabs = document.querySelectorAll('.tab-netsuite');

		// Inicializa el primer elemento como activo
		if (menuItems.length > 0 && tabs.length > 0) {
			menuItems[0].classList.add('active');
			tabs[0].classList.add('active');
		}

		// Agrega el evento click a cada elemento del menú
		menuItems.forEach((menuItem, index) => {
			menuItem.addEventListener('click', () => {
				// Remueve la clase 'active' de todos los elementos
				menuItems.forEach(item => item.classList.remove('active'));
				tabs.forEach(tab => tab.classList.remove('active'));

				// Agrega la clase 'active' al elemento clicado y su tab correspondiente
				menuItem.classList.add('active');
				if (tabs[index]) {
					tabs[index].classList.add('active');
				}
			});
		});
	});

</script>
</body>
</html>
