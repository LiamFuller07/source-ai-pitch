        <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Buscar el formulario dentro del contenedor con la clase '.popup-care'
            const popupForm = document.querySelector('.popup-care form');
            
            if (popupForm) {
                // Detectar el envío exitoso del formulario Contact Form 7
                popupForm.addEventListener('wpcf7mailsent', function () {
                    // Agregar un retraso antes de simular el clic
                    setTimeout(() => {
                        // Buscar el enlace con el ID "download-ebook"
                        const downloadLink = document.getElementById('download-ebook');
                        
                        if (downloadLink) {
                            downloadLink.click(); // Simular el click en el enlace para descargar el archivo
                        } else {
                            console.error('No se encontró el enlace con ID "download-ebook".');
                        }
                    }, 500); // 500 ms de retraso
                });
            } else {
                console.error('No se encontró el formulario dentro de .popup-care.');
            }
        });
    </script>
